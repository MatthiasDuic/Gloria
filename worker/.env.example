# --- Server ---
PORT=8080
LOG_LEVEL=info

# Shared HMAC secret used by Vercel <Connect><Stream> custom parameter to
# authenticate the call. Generate with: openssl rand -hex 32
STREAM_SHARED_SECRET=change-me

# --- Provider keys ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-phonecall
DEEPGRAM_LANGUAGE=de
# Endpointing-Tuning (Pause in ms, nach der Deepgram als Satzende interpretiert).
# Defaults: 1400/2400. Erhöhen, wenn Anrufer zu früh unterbrochen werden.
DEEPGRAM_ENDPOINTING_MS=1400
DEEPGRAM_UTTERANCE_END_MS=2400
# Komma-getrennte Keyword-Hints inkl. Boost-Suffix ":2" / ":1.5".
# Leer lassen für die deutsche Versicherungs-Default-Liste in worker/src/asr.ts.
DEEPGRAM_KEYWORDS=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- App callback (Vercel) ---
# Worker POSTs final transcripts/outcomes here (same Postgres-backed app).
APP_BASE_URL=https://gloria.agentur-duic-sprockhoevel.de
APP_INTERNAL_TOKEN=
